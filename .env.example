# Required
REDIS_URL=redis://default:password@host:port
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Optional
PORT=5000
LOG_LEVEL=info
NODE_ENV=development

# Comma-separated list of allowed origins. Use * for any.
CORS_ORIGINS=*

# Maximum upload concurrency to Discord (5 req/5s rate limit)
DISCORD_UPLOAD_CONCURRENCY=2

# Default TTL for stored files in seconds (0 = no expiry)
FILE_TTL_SECONDS=0

# Range size in bytes for partial responses
DEFAULT_RANGE_SIZE=5242880
